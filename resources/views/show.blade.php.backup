.fm-side-head-title { font-size: 13px; font-weight: 500; color: #374151; }
.fm-side-body { padding: 14px 16px; }
.fm-meta-row { display: flex; align-items: flex-start; gap: 10px; padding: 11px 0; border-bottom: 1px solid #f3f4f6; }
.fm-meta-row:last-child { border-bottom: none; padding-bottom: 0; }
